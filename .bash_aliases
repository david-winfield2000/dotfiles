# Navigation
alias ..="cd .."
alias ~="cd ~"

# Listing
alias la="ls -A"

# Git
alias lg="lazygit"

# Python
alias python="python3"

# Misc
alias c="clear"
alias h="history"
alias reload="source ~/.bashrc"

# Tmux
alias t="tmux"
alias ta="tmux a"
alias tn="tmux new -s"
alias tk="tmux kill-session -t"
