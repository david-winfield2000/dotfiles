# Navigation
alias ..="cd .."
alias ...="cd ../.."
alias ~="cd ~"

# Listing
alias ll="ls -alF"
alias la="ls -A"
alias l="ls -CF"

# Git shortcuts
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gp="git push"
alias gl="git log --oneline --graph --decorate"

# Python
alias python="python3"
alias py="python3"

# Misc
alias c="clear"
alias h="history"
alias reload="source ~/.bashrc"

